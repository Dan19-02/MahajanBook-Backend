# NVIDIA Integrate API key used for MiniMax-M3. Create one at https://build.nvidia.com
NVIDIA_API_KEY=your-nvidia-api-key-here

# Port the backend listens on.
PORT=3001

# Comma-separated list of allowed CORS origins (the frontend dev server).
CORS_ORIGIN=http://localhost:3000

# Secret used to sign JWTs. MUST be set to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# JWT lifetime in seconds (default 7 days).
JWT_EXPIRES_IN_SECONDS=604800

# SQLite database file path.
DB_PATH=./ledgix.db

# Model + base URL. Override only if you need a different model or gateway.
MINIMAX_MODEL=minimaxai/minimax-m3
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Timeout (ms) for the MiniMax request before the server gives up.
NVIDIA_TIMEOUT_MS=30000

# WhatsApp Business API (optional). When both TOKEN and PHONE_ID are set, the
# backend auto-sends due reminders on a schedule. Get these from Meta's
# WhatsApp Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v21.0
# How often the auto-send scheduler runs (ms). Default 5 minutes.
WHATSAPP_SCHEDULER_INTERVAL_MS=300000
