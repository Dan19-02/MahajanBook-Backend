# NVIDIA Integrate API key used for MiniMax-M3. Create one at https://build.nvidia.com
NVIDIA_API_KEY=your-nvidia-api-key-here

# Port the backend listens on.
PORT=3001

# Comma-separated list of allowed CORS origins (the frontend dev server).
CORS_ORIGIN=http://localhost:3000

# Proxy hops to trust for the real client IP (rate-limiting / req.ip). Set to 1
# when deployed behind a reverse proxy (Render/Heroku/Nginx); leave blank otherwise.
TRUST_PROXY=

# Google sign-in via Butterbase. Set BUTTERBASE_APP_ID to your butterbase app id
# (e.g. app_xxxx) — when set, POST /api/auth/google verifies a butterbase session
# and signs the user into MahajanBook. Must match the frontend's
# VITE_BUTTERBASE_APP_ID. Leave blank to disable Google sign-in.
BUTTERBASE_APP_ID=
BUTTERBASE_API_BASE=https://api.butterbase.ai

# Secret used to sign JWTs. MUST be set to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# JWT lifetime in seconds (default 7 days).
JWT_EXPIRES_IN_SECONDS=604800

# PostgreSQL connection string (required). Works with Render, Supabase, Neon, etc.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ledgix
# SSL for the DB connection: leave blank to auto-detect (on for remote hosts,
# off for localhost), or force with "true" / "false".
DATABASE_SSL=

# Model + base URL. Override only if you need a different model or gateway.
MINIMAX_MODEL=minimaxai/minimax-m3
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Timeout (ms) for the MiniMax request before the server gives up.
NVIDIA_TIMEOUT_MS=30000

# WhatsApp Business API (optional). When both TOKEN and PHONE_ID are set, the
# backend auto-sends due reminders on a schedule. Get these from Meta's
# WhatsApp Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v21.0
# How often the auto-send scheduler runs (ms). Default 5 minutes.
WHATSAPP_SCHEDULER_INTERVAL_MS=300000

# Razorpay subscription billing (optional). When KEY_ID + KEY_SECRET are set,
# the Plans page can take payments. Create one monthly Subscription Plan per tier
# in the Razorpay dashboard and paste their plan_ids below.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (Dashboard → Settings → Webhooks). Point the webhook at
# POST https://<your-backend>/api/billing/webhook for these events:
# subscription.activated, subscription.charged, subscription.halted,
# subscription.cancelled, subscription.completed.
RAZORPAY_WEBHOOK_SECRET=
# Subscription Plan IDs (look like "plan_XXXXXXXXXXXX") for each tier.
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_GROWTH=
RAZORPAY_PLAN_UNLIMITED=
